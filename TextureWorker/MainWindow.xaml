<Window x:Class="TextureWorker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TextureWorker"
        mc:Ignorable="d"
        Title="TextureWorker" Height="500" Width="480" Background="#FF454545" ResizeMode="NoResize" Icon="icon.png">
    <ScrollViewer HorizontalAlignment="Right" Height="500" VerticalAlignment="Top" Width="460">
        <Grid x:Name="My_reTextrueGrid" HorizontalAlignment="Left" Height="500" VerticalAlignment="Top" Width="440"
              Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="Input" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0"
                       Foreground="#FFBFBFBF" FontSize="12" />
            <ListBox x:Name="My_ListBox_T" Grid.Column="0" HorizontalAlignment="Left" Height="190"
                     VerticalAlignment="Top" Width="200" Margin="10,35,0,0" Foreground="#FFBFBFBF"
                     Background="#7F1D1D1D" AllowDrop="True" DragEnter="My_ListBox_T_DragEnter"
                     Drop="My_ListBox_T_Drop" />
            <TextBlock x:Name="My_PsText_T" Grid.Column="0" HorizontalAlignment="Left" TextWrapping="Wrap"
                       Text="Drag and drop images here" VerticalAlignment="Top" Margin="50,100,0,0" Width="120"
                       Foreground="#FFBFBFBF" TextAlignment="Center" />

            <CheckBox x:Name="My_T_UseInputRes" Grid.Column="0" Content="Use input resolution"
                      HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,225,0,0" Foreground="#FFBFBFBF"
                      IsChecked="True" />
            <TextBlock Text="Resolution:" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top"
                       Margin="10,255,0,0" Width="80" Foreground="#FFBFBFBF" TextAlignment="Left" />
            <TextBox x:Name="My_T_ParseX" Grid.Column="0" HorizontalAlignment="Left" Height="25" TextWrapping="Wrap"
                     VerticalAlignment="Top" Width="50" Margin="95,250,0,0" Background="#7F1D1D1D"
                     Foreground="#FFBFBFBF">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="IsEnabled" Value="False" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=My_T_UseInputRes}" Value="False">
                                <Setter Property="IsEnabled" Value="True" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <TextBlock Grid.Column="0" HorizontalAlignment="Left" TextWrapping="Wrap" Text="x" VerticalAlignment="Top"
                       Margin="150,255,0,0" Width="15" Foreground="#FFBFBFBF" TextAlignment="Center" />
            <TextBox x:Name="My_T_ParseY" Grid.Column="0" HorizontalAlignment="Left" Height="25" TextWrapping="Wrap"
                     VerticalAlignment="Top" Width="50" Margin="170,250,0,0" Background="#7F1D1D1D"
                     Foreground="#FFBFBFBF">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="IsEnabled" Value="False" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=My_T_UseInputRes}" Value="False">
                                <Setter Property="IsEnabled" Value="True" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <Button x:Name="My_B_ReReslutation" Grid.Column="0" Content="Batch Convert Resolution"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Height="25" Background="#FF595959"
                    Foreground="#FFBFBFBF" Margin="10,285,0,0" Click="My_B_ReReslutation_Click" />

            <Button x:Name="My_B_Gray" Grid.Column="0" Content="Batch Convert to Grayscale" HorizontalAlignment="Left"
                    VerticalAlignment="Top" Width="200" Height="25" Background="#FF595959" Foreground="#FFBFBFBF"
                    Margin="10,320,0,0" Click="My_B_Gray_Click" />
            <TextBlock Grid.Column="0" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Top"
                       Margin="10,355,0,0" Width="100" Foreground="#FFBFBFBF" TextAlignment="Left"
                       Text="Blur Strength:" />
            <Slider x:Name="My_T_BlurSlider" Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left"
                    Width="100" Margin="110,353,0,0" Minimum="1" Value="1" Foreground="Gray" Maximum="4" />
            <Button x:Name="My_B_Blur" Grid.Column="0" Content="Batch Blur (Slow)" HorizontalAlignment="Left"
                    VerticalAlignment="Top" Width="200" Height="25" Background="#FF595959" Foreground="#FFBFBFBF"
                    Margin="10,385,0,0" Click="My_B_Blur_Click" Cursor="" />

            <TextBlock Text="Output" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Top"
                       Margin="10,10,0,0" Foreground="#FFBFBFBF" FontSize="12" />
            <TextBlock Grid.Column="1" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Convert to:"
                       VerticalAlignment="Top" Margin="10,35,0,0" Width="80" Foreground="#FFBFBFBF"
                       TextAlignment="Left" />
            <ComboBox x:Name="My_ComBox" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Top" Width="120"
                      Margin="90,30,0,0" Background="Black" Foreground="#FF2A2A2A" BorderBrush="#FF2A2A2A"
                      SelectedIndex="10">
                <ComboBoxItem Content=".jpg" />
                <ComboBoxItem Content=".jpeg" />
                <ComboBoxItem Content=".png" />
                <ComboBoxItem Content=".tif" />
                <ComboBoxItem Content=".tiff" />
                <ComboBoxItem Content=".wmf" />
                <ComboBoxItem Content=".emf" />
                <ComboBoxItem Content=".bmp" />
                <ComboBoxItem Content=".gif" />
                <ComboBoxItem Content=".ico" />
                <ComboBoxItem Content=".dds" />
            </ComboBox>
            <TextBlock Grid.Column="1" HorizontalAlignment="Left" TextWrapping="Wrap" Text="DDS format:"
                       VerticalAlignment="Top" Margin="10,70,0,0" Width="80" Foreground="#FFBFBFBF"
                       TextAlignment="Left" />
            <ComboBox x:Name="My_DdsFormat" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Top"
                      Width="120" Margin="90,65,0,0" Background="Black" Foreground="#FF2A2A2A" BorderBrush="#FF2A2A2A"
                      SelectedIndex="0">
                <ComboBoxItem Content="RGBA32" />
                <ComboBoxItem Content="BC1" />
                <ComboBoxItem Content="BC3" />
                <ComboBoxItem Content="BC7" />
            </ComboBox>
            <Button x:Name="My_B_ConverImage" Grid.Column="1" Content="Batch Convert Format" HorizontalAlignment="Left"
                    VerticalAlignment="Top" Width="200" Height="25" Background="#FF595959" Foreground="#FFBFBFBF"
                    Margin="10,105,0,0" Click="My_B_ConverImage_Click" />

            <TextBlock Grid.Column="1" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Top"
                       Margin="10,150,0,0" Width="120" Foreground="#FFBFBFBF" TextAlignment="Left"
                       Text="Invert Channels:" />
            <CheckBox x:Name="My_T_CB_R" Grid.Column="1" Content="R" HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="10,175,0,0" Foreground="#FFBFBFBF" IsChecked="True" />
            <CheckBox x:Name="My_T_CB_G" Grid.Column="1" Content="G" HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="60,175,0,0" Foreground="#FFBFBFBF" IsChecked="True" />
            <CheckBox x:Name="My_T_CB_B" Grid.Column="1" Content="B" HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="110,175,0,0" Foreground="#FFBFBFBF" IsChecked="True" />
            <CheckBox x:Name="My_T_CB_A" Grid.Column="1" Content="A" HorizontalAlignment="Left" VerticalAlignment="Top"
                      Margin="160,175,0,0" Foreground="#FFBFBFBF" IsChecked="True" />
            <Button x:Name="My_B_Invert" Grid.Column="1" Content="Batch Invert Colors" HorizontalAlignment="Left"
                    VerticalAlignment="Top" Width="200" Height="25" Background="#FF595959" Foreground="#FFBFBFBF"
                    Margin="10,205,0,0" Cursor="" Click="My_B_Invert_Click" />

            <TextBlock Grid.ColumnSpan="2" HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Top"
                       Margin="180,480,0,0" Width="80" Foreground="#FFBFBFBF" TextAlignment="Center"
                       Text=" -ZeroSkyline-" FontSize="10" />
        </Grid>
    </ScrollViewer>
</Window>
